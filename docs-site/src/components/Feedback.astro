---
interface Props {
  pageTitle?: string;
  pagePath?: string;
  repoUrl?: string;
}

const {
  pageTitle = '',
  pagePath = '',
  repoUrl = 'https://github.com/asachs01/beacon'
} = Astro.props;

const issueBase = `${repoUrl}/issues/new`;

const feedbackParams = new URLSearchParams({
  title: `Docs feedback: ${pageTitle}`,
  labels: 'documentation',
  body: `**Page:** ${pagePath}\n\n**Feedback:**\n\n`,
});
---

<div class="mt-12 pt-8 border-t border-[var(--td-border)]">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p class="text-sm text-[var(--td-text-muted)]">Was this page helpful?</p>
    <a
      href={`${issueBase}?${feedbackParams.toString()}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg border border-[var(--td-border)] text-[var(--td-text-muted)] hover:text-[var(--td-text)] hover:border-[var(--td-text)] transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      Give Feedback
    </a>
  </div>
</div>
